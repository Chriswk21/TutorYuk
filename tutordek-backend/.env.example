# Supabase application configuration
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
# Optional server-side key if you need privileged operations on Supabase
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# PostgreSQL connection for TypeORM if you still use a local or hosted database
DATABASE_URL="postgres://user:password@host:5432/dbname"

# App port
PORT=3000
